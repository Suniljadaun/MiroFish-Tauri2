{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiroFish",
  "version": "0.1.0",
  "identifier": "com.mirofish.desktop",
  "build": {
    "frontendDist": "../MiroFish/frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd ../MiroFish/frontend && npm run dev",
    "beforeBuildCommand": "cd ../MiroFish/frontend && npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MiroFish",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "externalBin": [
      "binaries/mirofish-server"
    ]
  },
  "plugins": {
    "shell": {
      "all": true,
      "open": true,
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/mirofish-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "store": {
      "autoSave": 500
    }
  }
}
